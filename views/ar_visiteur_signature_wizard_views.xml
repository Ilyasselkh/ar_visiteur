<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_visiteur_signature_wizard_form" model="ir.ui.view">
        <field name="name">ar.visiteur.signature.wizard.form</field>
        <field name="model">ar.visiteur.signature.wizard</field>
        <field name="arch" type="xml">
            <form string="Signature visiteur" class="ar_visiteur_signature_wizard">
                <sheet>
                    <field name="visiteur_id" invisible="1"/>
                    <div class="ar_visiteur_signature_box">
                        <field name="signature" widget="signature" nolabel="1"/>
                    </div>
                </sheet>
                <footer>
                    <button name="action_valider_signature" string="Valider la signature" type="object" class="btn-primary"/>
                    <button string="Fermer" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
