<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ar_visiteur_config_list" model="ir.ui.view">
        <field name="name">ar.visiteur.config.list</field>
        <field name="model">ar.visiteur.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="pdf_filename"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ar_visiteur_config_form" model="ir.ui.view">
        <field name="name">ar.visiteur.config.form</field>
        <field name="model">ar.visiteur.config</field>
        <field name="arch" type="xml">
            <form string="Paramétrage visiteur">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="survey_id"/>
                            <field name="quiz_validity_months"/>
                        </group>
                        <group>
                            <field name="pdf_file" filename="pdf_filename" widget="pdf_viewer"/>
                            <field name="pdf_filename" invisible="1"/>
                        </group>
                    </group>
                    <chatter/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ar_visiteur_config" model="ir.actions.act_window">
        <field name="name">Paramétrage</field>
        <field name="res_model">ar.visiteur.config</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
